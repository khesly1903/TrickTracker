// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StudentType {
  CHILD
  ADULT
}

enum Role {
  ADMIN
  MANAGER
  OWNER
  INSTRUCTOR
  PARENT
  STUDENT
  VISITOR
}

enum ClassTypes {
  PRIVATE
  GROUP
  MAKEUP
  WORKSHOP
  EVENT
}

enum ContactTypes {
  PARENT
  GUARDIAN
  EMERGENCY
}

enum ProgramLevels {
  BEGINNER
  INTERMEDIATE
  TODDLER
  ALL_LEVELS
}

enum SkillType {
  SKILL
  TRICK
}

enum SkillStatus {
  NOT_STARTED
  LEARNING
  WITH_HELP
  MASTERED
}

enum Gender {
  BOYS
  GIRLS
  ALL_GENDER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ScheduleType {
  CLASS
  HOLIDAY
  CANCELLED
  MAKEUP
}

enum Stage {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  roles        Role[]

  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  refreshToken String?

  studentProfile    Student?
  contactProfile    Contact?
  instructorProfile Instructor?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Student {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                 String
  surname              String
  type                 StudentType
  dob                  DateTime
  injuries             String[]
  phoneNumber          String?
  secondaryPhoneNumber String?
  whatsappPhoneNumber  String?
  school               String?
  isActive             Boolean          @default(true)
  studentContacts      StudentContact[]
  studentPrograms      StudentProgram[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Contact {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                 String
  surname              String
  type                 ContactTypes[]
  phoneNumber          String
  secondaryPhoneNumber String?
  whatsappPhoneNumber  String
  email                String?          @unique
  isActive             Boolean          @default(true)
  studentContacts      StudentContact[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Instructor {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                 String
  surname              String
  isActive             Boolean @default(true)
  phoneNumber          String
  secondaryPhoneNumber String?
  whatsappPhoneNumber  String

  mainPrograms   ProgramLocation[] @relation("MainInstructor")
  backupPrograms ProgramLocation[] @relation("BackupInstructors")

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Class {
  id       String     @id @default(uuid())
  name     String
  type     ClassTypes @default(GROUP)
  programs Program[]
  isActive Boolean    @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Program {
  id                String            @id @default(uuid())
  
  name              String
  isActive          Boolean           @default(true)
  Stage             Stage[]
  gender            Gender            @default(ALL_GENDER)
  requiredEquipment String[]

  programSkills     ProgramSkill[]
  
  startDate       DateTime         @db.Timestamptz
  endDate         DateTime         @db.Timestamptz

  minAge   Int
  maxAge   Int
  minLevel ProgramLevels
  maxLevel ProgramLevels

  inheritedClass Class  @relation(fields: [classId], references: [id])
  classId        String

  programLocations ProgramLocation[]
}

model ProgramLocation {
  id        String   @id @default(uuid())
  programId String
  locationId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  price             Float
  capacity          Int
  
  instructor        Instructor?       @relation("MainInstructor", fields: [instructorId], references: [id])
  instructorId      String?
  backupInstructors Instructor[]      @relation("BackupInstructors")
  
  studentPrograms   StudentProgram[]
  schedules ProgramSchedule[]
  sessions  ProgramSession[]

  @@unique([programId, locationId])
}

model ProgramSchedule {
  id        String       @id @default(uuid())
  dayOfWeek DayOfWeek
  startTime DateTime
  endTime   DateTime?
  duration  Int //minutes
  type      ScheduleType

  programLocation   ProgramLocation @relation(fields: [programLocationId], references: [id], onDelete: Cascade)
  programLocationId String

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model ProgramSession {
  id          String       @id @default(uuid())
  date        DateTime     @db.Timestamptz
  startTime   DateTime     @db.Timestamptz
  endTime     DateTime     @db.Timestamptz
  isCancelled Boolean      @default(false)
  type        ScheduleType @default(CLASS)

  programLocation   ProgramLocation @relation(fields: [programLocationId], references: [id], onDelete: Cascade)
  programLocationId String

  attendances Attendance[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Attendance {
  id       String  @id @default(uuid())
  attended Boolean
  note     String?

  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  studentProgramId String

  programSession   ProgramSession @relation(fields: [programSessionId], references: [id], onDelete: Cascade)
  programSessionId String

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([studentProgramId, programSessionId])
}

model Location {
  id       String    @id @default(uuid())
  name     String
  address  String
  isActive Boolean   @default(true)
  programLocations ProgramLocation[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model StudentProgram {
  id        String  @id @default(uuid())
  student   Student @relation(fields: [studentId], references: [id])
  programLocation   ProgramLocation @relation(fields: [programLocationId], references: [id], onDelete: Cascade)
  isActive  Boolean @default(true)
  studentId String
  programLocationId String

  attendances          Attendance[]
  studentProgramSkills StudentProgramSkill[]

  @@unique([studentId, programLocationId])
}

model StudentContact {
  student   Student @relation(fields: [studentId], references: [id])
  contact   Contact @relation(fields: [contactId], references: [id])
  studentId String
  contactId String
  relation  ContactTypes @default(PARENT)

  @@id([studentId, contactId])
}

model ProgramSkill {
  id        String  @id @default(uuid())
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String

  name  String
  type  SkillType
  stage Stage

  studentProgramSkills StudentProgramSkill[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([programId, name])
}

model StudentProgramSkill {
  id String @id @default(uuid())

  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  studentProgramId String

  programSkill   ProgramSkill @relation(fields: [programSkillId], references: [id], onDelete: Cascade)
  programSkillId String

  status     SkillStatus @default(NOT_STARTED)
  achievedAt DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([studentProgramId, programSkillId])
}
