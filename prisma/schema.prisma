// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StudentType {
  CHILD
  ADULT
}

enum Role {
  ADMIN
  MANAGER
  OWNER
  INSTRUCTOR
  PARENT
  STUDENT
  VISITOR
}

enum ClassTypes {
  PRIVATE
  GROUP
  MAKEUP
  WORKSHOP
  EVENT
}

enum ContactTypes {
  PARENT
  GUARDIAN
  EMERGENCY
}

enum SkillType {
  SKILL
  TRICK
}

enum Gender {
  BOYS
  GIRLS
  ALL_GENDER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ScheduleType {
  CLASS
  HOLIDAY
  CANCELLED
  MAKEUP
}

model Academy {
  id          String   @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  seqNumber   Int?     @unique

  ownerId     String   @unique
  owner       User     @relation("AcademyOwner", fields: [ownerId], references: [id])

  students    Student[]
  contacts    Contact[]
  instructors Instructor[]
  classes     Class[]
  programs    Program[]
  locations   Location[]
  enrollmentCounters AcademyEnrollmentCounter[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model AcademyEnrollmentCounter {
  academyId String
  year      Int
  lastSeq   Int    @default(0)
  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@id([academyId, year])
}

model User {
  id           String  @id @default(uuid())
  email        String? @unique
  loginId      String? @unique
  passwordHash String
  roles        Role[]

  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  refreshToken String?

  ownedAcademy      Academy?   @relation("AcademyOwner")

  studentProfile    Student?
  contactProfile    Contact?
  instructorProfile Instructor?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Student {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  name                 String
  surname              String
  type                 StudentType
  dob                  DateTime
  injuries             String[]
  phoneNumber          String?
  secondaryPhoneNumber String?
  whatsappPhoneNumber  String?
  school               String?
  enrollmentId         String?
  isActive             Boolean          @default(true)
  studentContacts      StudentContact[]
  studentPrograms      StudentProgram[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([academyId, enrollmentId])
  @@index([academyId])
}

model Contact {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  name                 String
  surname              String
  type                 ContactTypes[]
  phoneNumber          String
  secondaryPhoneNumber String?
  whatsappPhoneNumber  String
  email                String?          @unique
  enrollmentId         String?
  isActive             Boolean          @default(true)
  studentContacts      StudentContact[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([academyId, enrollmentId])
  @@index([academyId])
}

model Instructor {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  name                 String
  surname              String
  enrollmentId         String?
  isActive             Boolean @default(true)
  phoneNumber          String
  secondaryPhoneNumber String?
  whatsappPhoneNumber  String

  mainPrograms   ProgramLocation[] @relation("MainInstructor")
  backupPrograms ProgramLocation[] @relation("BackupInstructors")

  studentProgramSkillUpdates StudentProgramSkill[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([academyId, enrollmentId])
  @@index([academyId])
}

model Class {
  id       String     @id @default(uuid())
  name     String
  type     ClassTypes @default(GROUP)
  programs Program[]
  isActive Boolean    @default(true)

  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([academyId])
}

model Program {
  id                String            @id @default(uuid())

  name              String
  isActive          Boolean           @default(true)
  level             String?
  gender            Gender            @default(ALL_GENDER)
  requiredEquipment String[]

  programStages     ProgramStage[]

  startDate       DateTime         @db.Timestamptz
  endDate         DateTime         @db.Timestamptz

  minAge   Int
  maxAge   Int

  inheritedClass Class  @relation(fields: [classId], references: [id])
  classId        String

  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  programLocations ProgramLocation[]

  @@index([academyId])
}

model ProgramLocation {
  id        String   @id @default(uuid())
  programId String
  locationId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  price             Float
  capacity          Int
  
  instructor        Instructor?       @relation("MainInstructor", fields: [instructorId], references: [id])
  instructorId      String?
  backupInstructors Instructor[]      @relation("BackupInstructors")
  
  studentPrograms   StudentProgram[]
  schedules ProgramSchedule[]
  sessions  ProgramSession[]

  @@unique([programId, locationId])
}

model ProgramSchedule {
  id        String       @id @default(uuid())
  dayOfWeek DayOfWeek
  startTime DateTime     @db.Timestamptz
  endTime   DateTime?    @db.Timestamptz
  duration  Int //minutes
  type      ScheduleType

  programLocation   ProgramLocation @relation(fields: [programLocationId], references: [id], onDelete: Cascade)
  programLocationId String

  sessions ProgramSession[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model ProgramSession {
  id        String       @id @default(uuid())
  date      DateTime     @db.Timestamptz
  startTime DateTime     @db.Timestamptz
  endTime   DateTime     @db.Timestamptz
  type      ScheduleType @default(CLASS)

  programLocation   ProgramLocation @relation(fields: [programLocationId], references: [id], onDelete: Cascade)
  programLocationId String

  schedule   ProgramSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  scheduleId String?

  attendances Attendance[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Attendance {
  id       String  @id @default(uuid())
  attended Boolean
  note     String?

  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  studentProgramId String

  programSession   ProgramSession @relation(fields: [programSessionId], references: [id], onDelete: Cascade)
  programSessionId String

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([studentProgramId, programSessionId])
}

model Location {
  id       String    @id @default(uuid())
  name     String
  address  String
  isActive Boolean   @default(true)
  programLocations ProgramLocation[]

  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([academyId])
}

model StudentProgram {
  id        String  @id @default(uuid())
  student   Student @relation(fields: [studentId], references: [id])
  programLocation   ProgramLocation @relation(fields: [programLocationId], references: [id], onDelete: Cascade)
  isActive  Boolean @default(true)
  studentId String
  programLocationId String

  attendances          Attendance[]
  studentProgramSkills StudentProgramSkill[]

  @@unique([studentId, programLocationId])
}

model StudentContact {
  student   Student @relation(fields: [studentId], references: [id])
  contact   Contact @relation(fields: [contactId], references: [id])
  studentId String
  contactId String
  relation  ContactTypes @default(PARENT)

  @@id([studentId, contactId])
}

model ProgramStage {
  id          String         @id @default(uuid())
  name        String
  description String?
  program     Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId   String
  skills      ProgramSkill[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([programId, name])
}

model ProgramSkill {
  id          String       @id @default(uuid())
  name        String
  description String?
  type        SkillType
  stage       ProgramStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  stageId     String

  studentProgramSkills StudentProgramSkill[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([stageId, name])
}

model StudentProgramSkill {
  id String @id @default(uuid())

  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  studentProgramId String

  programSkill   ProgramSkill @relation(fields: [programSkillId], references: [id], onDelete: Cascade)
  programSkillId String

  status      Int     @default(0)
  note        String?
  updatedBy   Instructor? @relation(fields: [updatedById], references: [id])
  updatedById String?
  achievedAt  DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([studentProgramId, programSkillId])
}
